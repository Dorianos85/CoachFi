# Coach FI API configuration
# Copy this file to .env.local and paste real keys. Do not commit .env.local.

# Anthropic Claude Haiku for AI Coach Mila
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=256

# Optional OpenRouter fallback/provider for AI Coach Mila
# Set AI_PROVIDER=openrouter if you want OpenRouter to be tried before Anthropic.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MAX_TOKENS=256
AI_PROVIDER=

# ElevenLabs text-to-speech for Mila voice
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional locale-specific voice IDs for the PL / EN / JA demo
ELEVENLABS_PL_VOICE_ID=
ELEVENLABS_EN_VOICE_ID=
ELEVENLABS_JA_VOICE_ID=

# Supabase leaderboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LEADERBOARD_TABLE=leaderboard

# Solana Devnet NFT minting
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_MINT_KEYPAIR=
NEXT_PUBLIC_APP_URL=http://localhost:3000
